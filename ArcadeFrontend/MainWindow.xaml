<Window x:Class="ArcadeFrontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Arcade Frontend"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="#111111"
        Foreground="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E1E1E"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Arcade Frontend"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding CurrentScreen, StringFormat=Screen: {0}}"
                               FontSize="14"
                               Opacity="0.8"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#2D2D30"
                        Padding="14,8"
                        CornerRadius="6"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="14"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#1A1A1A"
                    CornerRadius="10"
                    Padding="16"
                    Margin="0,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding LeftPanelTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <Border Grid.Row="1"
                            Background="#202020"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,0,0,12">
                        <TextBlock Text="{Binding EmptyStateMessage}"
                                   TextWrapping="Wrap"
                                   Opacity="0.85"
                                   FontSize="14"/>
                    </Border>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding MainMenuItems}"
                             SelectedIndex="{Binding SelectedMenuIndex, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="22"
                             Visibility="{Binding MainMenuVisibility}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,12"
                                        Margin="0,0,0,10"
                                        Background="#252526"
                                        CornerRadius="8">
                                    <TextBlock Text="{Binding}"
                                               FontWeight="SemiBold"
                                               FontSize="22"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Games}"
                             SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="18"
                             Visibility="{Binding GamesVisibility}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10"
                                        Margin="0,0,0,8"
                                        Background="#252526"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="18"/>
                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="13"
                                                   Opacity="0.75"
                                                   Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Opacity="0.65"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#1A1A1A"
                        CornerRadius="10"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{Binding RightPanelTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding RightPanelHeadline}"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding RightPanelSubheadline}"
                                   FontSize="14"
                                   Opacity="0.75"
                                   Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding RightPanelBody}"
                                   TextWrapping="Wrap"
                                   Opacity="0.7"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <WrapPanel Grid.Row="1"
                           Margin="0,0,0,16">
<WrapPanel Grid.Row="1" Margin="0,0,0,16">
    <Button Content="Select / Launch"
            Click="OnSelectClicked"
            Padding="18,10"
            Margin="0,0,12,0"
            FontSize="16"/>
    <Button Content="Back"
            Click="OnBackClicked"
            Padding="18,10"
            Margin="0,0,12,0"
            FontSize="16"/>
    <Button Content="Diagnostics"
            Click="OnDiagnosticsClicked"
            Padding="18,10"
            Margin="0,0,12,0"
            FontSize="16"/>
    <Button Content="Exit"
            Click="OnExitClicked"
            Padding="18,10"
            FontSize="16"/>
</WrapPanel>
                </WrapPanel>

                <Border Grid.Row="2"
                        Background="#1A1A1A"
                        CornerRadius="10"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Diagnostics"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding DiagnosticsText}"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       Opacity="0.92"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="#161616"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Controls"
                               FontWeight="SemiBold"
                               FontSize="15"/>
                    <TextBlock Text="Up/Down: Navigate   Select/Start: Confirm   Back: Return   F1/Admin: Diagnostics   Exit button: Close app"
                               FontSize="13"
                               Opacity="0.7"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#2B2B2B"
                        CornerRadius="6"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding IsAttractModeActive, StringFormat=Attract Mode: {0}}"
                               FontSize="13"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
