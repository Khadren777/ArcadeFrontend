<Window x:Class="ArcadeFrontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Arcade Frontend"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="MenuBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#33000000" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="18,14" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#CC3AA0FF" />
                    <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLaunchAvailable}" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#FF05070B" />

        <Image Source="{Binding BackgroundImagePath}"
               Stretch="UniformToFill"
               Opacity="0.38"
               IsHitTestVisible="False" />

        <MediaElement x:Name="AttractVideoPlayer"
                      Source="{Binding AttractVideoPath}"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      Stretch="UniformToFill"
                      Volume="0"
                      IsMuted="True"
                      MediaEnded="AttractVideoPlayer_MediaEnded"
                      MediaFailed="AttractVideoPlayer_MediaFailed"
                      Visibility="{Binding ShowAttractVideo, Converter={StaticResource BoolToVisibilityConverter}}"
                      IsHitTestVisible="False" />

        <Rectangle Fill="#B0000000">
            <Rectangle.Style>
                <Style TargetType="Rectangle">
                    <Setter Property="Opacity" Value="1" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DimBackgroundUnderVideo}" Value="False">
                            <Setter Property="Opacity" Value="0.72" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Rectangle.Style>
        </Rectangle>

        <Grid Margin="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1.35*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="{Binding TitleText}"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SubtitleText}"
                               Foreground="#D0D7E2"
                               FontSize="18"
                               Margin="0,10,0,0" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#22131A24"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MenuItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MenuBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="White"
                                                           FontSize="24"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LaunchIssue}"
                                                           Foreground="#FFFF8C8C"
                                                           FontSize="13"
                                                           Margin="0,6,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsLaunchAvailable}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="★"
                                                           Foreground="#FFFFD24A"
                                                           FontSize="20"
                                                           HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Game.IsFavorite}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="#AA0C1119"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16"
                        Margin="0,24,0,0">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#FFEAF2FF"
                               FontSize="16"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Margin="28,0,0,0"
                    Background="#99121922"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18"
                    Visibility="{Binding ShowDiagnosticsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Diagnostics"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DiagnosticLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#22000000"
                                            CornerRadius="8"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#FFD7E3F4"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
